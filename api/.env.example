# IntelDoc backend env (copy to .env). Localhost defaults target the Compose
# stack's published ports, so you can run the app locally via `uv run` against it.
# Inside Compose, the app/worker/migrate services override hosts with service names.

APP_ENV=dev

# --- Database (per role) ---
# App runtime (asyncpg, least-privileged `app` role)
DATABASE_URL_APP=postgresql+asyncpg://app:app@localhost:5432/inteldoc
# Admin aggregate reads (asyncpg, PII-blind `admin_readonly` role)
DATABASE_URL_ADMIN_READONLY=postgresql+asyncpg://admin_readonly:admin_readonly@localhost:5432/inteldoc
# Migrations (sync psycopg). In dev this is the superuser so role bootstrap runs;
# in prod use a dedicated DDL-only `migration_owner`.
DATABASE_URL_MIGRATION=postgresql+psycopg://inteldoc:inteldoc@localhost:5432/inteldoc

# --- Redis (cache + arq broker) ---
REDIS_URL=redis://localhost:6379/0

# --- Object storage (MinIO, S3-compatible) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=ru-central1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=inteldoc

# --- Security (CHANGE IN PROD; audit_pepper compromise = reversible audit subject) ---
JWT_SIGNING_KEY=dev-insecure-change-me-min-32-bytes-long
AUDIT_PEPPER=dev-insecure-audit-pepper
# Separate secret for hashing stored OTP codes (kept apart from AUDIT_PEPPER).
OTP_PEPPER=dev-insecure-otp-pepper

# --- Patient OTP / SMS (ENG-09) ---
# "mock" = dev/demo: no SMS sent, the fixed DEV_OTP_CODE below is accepted.
# A real vendor id (e.g. "smsru") issues + delivers a random code and rejects «0000».
OTP_PROVIDER=mock

# --- Dev ---
# Honoured ONLY while OTP_PROVIDER=mock. A real provider makes it inert.
DEV_OTP_CODE=0000
