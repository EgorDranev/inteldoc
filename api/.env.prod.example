# IntelDoc PROD env — copy to `.env` on the VPS and fill every placeholder.
#   cp .env.prod.example .env
# Used by docker-compose.prod.yml (env_file: .env + ${VAR} interpolation).
# This is a clinical-pilot DEMO host (no real PHI) — but treat every secret below
# as real: it is internet-reachable and persistent. See DEPLOY.md.

# Runtime mode. MUST be `prod` here (dev relaxes OTP/error verbosity).
APP_ENV=prod

# --- Public domain (Caddy auto-TLS) ------------------------------------------
# The hostname whose DNS A-record points at this VPS. Caddy issues a Let's Encrypt
# cert for it. The frontend will call https://${DOMAIN}/v1/... (no port).
DOMAIN=api.inteldoc.example.ru

# --- Postgres bootstrap + per-role passwords ---------------------------------
# The superuser bootstraps the DB and is used by the `migrate` one-shot so that
# migration 0001 can create the least-privileged `app` / `admin_readonly` roles.
POSTGRES_DB=inteldoc                                   # database name (keep `inteldoc`)
POSTGRES_SUPERUSER=inteldoc                            # superuser / bootstrap role name
POSTGRES_SUPERUSER_PASSWORD=CHANGE_ME_strong_superuser_pw   # strong; generate: openssl rand -base64 24
#
# NOTE on the runtime roles: migration 0001 CREATEs `app` / `admin_readonly` with
# FIXED passwords (`app` / `admin_readonly`). The compose DSNs use those literals.
# That is safe here because Postgres publishes NO host port in prod — the roles are
# reachable only on the internal compose network. To use strong role passwords,
# add a post-migrate one-shot that runs `ALTER ROLE app PASSWORD '<env>'` and
# parameterise the DSNs in docker-compose.prod.yml. Not needed for the demo.

# --- Database URLs (per role) ------------------------------------------------
# NOTE: docker-compose.prod.yml sets the three runtime/migration DSNs on the
# app/worker/migrate containers directly (app/admin_readonly use the pinned
# literals; migrate uses the superuser parts above), so you do NOT need to set
# these by hand for the Compose stack. Listed here only for running OUTSIDE Compose
# (the app reads these exact names — see app/core/config.py):
#   App runtime (asyncpg, least-privileged `app` role — password pinned by 0001):
# DATABASE_URL_APP=postgresql+asyncpg://app:app@postgres:5432/inteldoc
#   Admin aggregate reads (asyncpg, PII-blind `admin_readonly` role — pinned):
# DATABASE_URL_ADMIN_READONLY=postgresql+asyncpg://admin_readonly:admin_readonly@postgres:5432/inteldoc
#   Migrations (sync psycopg, superuser so role bootstrap runs):
# DATABASE_URL_MIGRATION=postgresql+psycopg://inteldoc:CHANGE_ME_strong_superuser_pw@postgres:5432/inteldoc

# --- Redis (cache + arq broker) ----------------------------------------------
# Compose overrides this to redis://redis:6379/0 for the containers; set it here
# too for out-of-Compose use. Redis is internal-only (no host port in prod).
REDIS_URL=redis://redis:6379/0

# --- Object storage (MinIO in-stack, S3-compatible) --------------------------
# In-stack MinIO defaults. These creds become the MinIO root user/password AND the
# app's S3 access keys. Compose overrides S3_ENDPOINT_URL to http://minio:9000 for
# the containers (internal). Generate strong values for prod.
S3_ENDPOINT_URL=http://minio:9000                      # in-stack MinIO; container-internal
S3_REGION=ru-central1                                  # arbitrary for MinIO; real for managed S3
S3_ACCESS_KEY=CHANGE_ME_minio_access_key               # = MinIO root user; openssl rand -hex 12
S3_SECRET_KEY=CHANGE_ME_minio_secret_key               # = MinIO root password; openssl rand -base64 24
S3_BUCKET=inteldoc                                     # bucket created by the createbuckets one-shot
#
# EXTERNAL S3 ALTERNATIVE (e.g. Yandex Object Storage): remove the minio +
# createbuckets services from docker-compose.prod.yml, then point the five S3_*
# vars at the managed bucket, e.g.:
#   S3_ENDPOINT_URL=https://storage.yandexcloud.net
#   S3_REGION=ru-central1
#   S3_ACCESS_KEY=<static access key id>
#   S3_SECRET_KEY=<static secret>
#   S3_BUCKET=<your-bucket-name>

# --- Security (CHANGE THESE — they are the trust root) -----------------------
# JWT signing key — MUST be >= 32 random bytes. Generate:
#   openssl rand -base64 48
JWT_SIGNING_KEY=CHANGE_ME_min_32_random_bytes
# Audit pepper — HMAC pepper for audit_subject_id. Compromise = reversible audit
# subjects, so guard it. Generate:
#   openssl rand -base64 48
AUDIT_PEPPER=CHANGE_ME_random_audit_pepper

# --- CORS --------------------------------------------------------------------
# Browser origins allowed to call the API. Set to EXACTLY the Vercel frontend
# origin (scheme + host, no trailing slash, no path). Multiple origins are
# comma-separated, no spaces required. Example for a Vercel deploy:
CORS_ORIGINS=https://your-frontend.vercel.app

# --- OCR engine --------------------------------------------------------------
# `stub` is the code default (fixture extraction, no OCR runtime). For the pilot
# demo we want real extraction, so set `tesseract`. NOTE: this requires the
# Tesseract binary + rus/eng language packs in the image — these are being added
# to the Dockerfile in a separate change. Until that lands, leave OCR_ENGINE=stub
# (the demo seed data renders fine without real OCR).
OCR_ENGINE=tesseract
OCR_TESSERACT_LANG=rus+eng                             # rus needed for RU lab reports

# --- Patient OTP / SMS provider (ENG-09) -------------------------------------
# Real production MUST use a real SMS vendor. With OTP_PROVIDER=smsru the fixed
# «0000» shortcut is rejected and the patient login OTP is a random, delivered,
# attempt-capped code (arbitrary-patient impersonation closed).
#
# `smsru` is currently a seam (app/infra/otp/providers.py:SmsRuProvider) — IMPLEMENT
# the vendor HTTP call + credentials before launch, or the first OTP request fails
# loud. Do NOT set OTP_PROVIDER=mock here: with APP_ENV=prod the app REFUSES TO BOOT
# on the mock provider (it would re-open the «0000» backdoor).
OTP_PROVIDER=smsru
# SMSRU_API_KEY=CHANGE_ME

# Dedicated OTP-code hashing secret (distinct from AUDIT_PEPPER).
OTP_PEPPER=CHANGE_ME_random_otp_pepper

# Escape hatch for a DEMO host that intentionally keeps «0000» under APP_ENV=prod:
# set both OTP_PROVIDER=mock and ALLOW_DEV_OTP=1 (boots with a loud warning).
# Leave UNSET for a real-PHI deploy. (Cleaner: run such a demo as APP_ENV=demo.)
# ALLOW_DEV_OTP=0

# DEV_OTP_CODE is intentionally NOT set in production — it is inert under a real
# provider anyway.
